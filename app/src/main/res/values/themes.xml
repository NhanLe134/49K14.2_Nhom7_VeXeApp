<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Nhom7VeXeApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
    </style>

    <style name="Theme.Nhom7VeXeApp" parent="Base.Theme.Nhom7VeXeApp" />

    <!-- Style cho Label (Tiêu đề trường nhập liệu) -->
    <style name="LabelStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">15dp</item>
        <item name="android:textColor">#111827</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Style cho Input (Ô nhập liệu) -->
    <style name="InputStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:background">@drawable/bg_input_white</item>
        <item name="android:paddingHorizontal">15dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#111827</item>
    </style>
</resources>
