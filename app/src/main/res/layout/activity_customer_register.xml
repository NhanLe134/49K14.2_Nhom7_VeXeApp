<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#00B0FF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="15dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_back_chevron"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Đăng ký"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- STEP 1: PHONE ENTRY -->
    <LinearLayout
        android:id="@+id/layoutStepPhone"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="30dp"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header">

        <ImageView
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_marginTop="20dp"
            android:src="@drawable/logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="Đăng ký"
            android:textColor="#005B96"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Vui lòng nhập số điện thoại để tạo tài khoản mới"
            android:textColor="#0091D5"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/edtPhoneInput"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="30dp"
            android:background="@drawable/bg_input_white"
            android:hint="Vui lòng nhập số điện thoại"
            android:inputType="phone"
            android:paddingHorizontal="15dp"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerifyPhone"
            android:layout_width="wrap_content"
            android:layout_height="55dp"
            android:layout_marginTop="25dp"
            android:backgroundTint="#00B0FF"
            android:text="Xác nhận số điện thoại"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:cornerRadius="8dp" />
    </LinearLayout>

    <!-- STEP 2: REGISTRATION FORM -->
    <ScrollView
        android:id="@+id/layoutStepForm"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="20dp"
                android:text="FORM ĐĂNG KÝ TÀI KHOẢN KHÁCH HÀNG"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="15dp"
                app:cardElevation="4dp"
                android:layout_marginHorizontal="5dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Họ và tên -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Họ và tên"
                        android:textSize="12sp"
                        android:textColor="#999999"/>
                    <EditText
                        android:id="@+id/edtFullName"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:layout_marginTop="5dp"
                        android:background="@drawable/bg_input_white"
                        android:hint="Nhập họ và tên"
                        android:paddingHorizontal="15dp"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/tvErrorFullName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="*Họ và tên không được để trống"
                        android:textColor="#D32F2F"
                        android:textSize="11sp"
                        android:textStyle="italic"
                        android:visibility="gone" />

                    <!-- Ngày sinh -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="15dp"
                        android:text="Ngày sinh"
                        android:textSize="12sp"
                        android:textColor="#999999"/>
                    <EditText
                        android:id="@+id/edtDob"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:layout_marginTop="5dp"
                        android:background="@drawable/bg_input_white"
                        android:clickable="true"
                        android:drawableEnd="@android:drawable/ic_menu_my_calendar"
                        android:focusable="false"
                        android:hint="Vui lòng chọn ngày sinh"
                        android:paddingHorizontal="15dp"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/tvErrorDob"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="*Vui lòng chọn ngày sinh"
                        android:textColor="#D32F2F"
                        android:textSize="11sp"
                        android:textStyle="italic"
                        android:visibility="gone" />

                    <!-- Ảnh đại diện -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="15dp"
                        android:text="Ảnh đại diện"
                        android:textSize="12sp"
                        android:textColor="#999999"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/tvFileName"
                            android:layout_width="0dp"
                            android:layout_height="45dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input_white"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="15dp"
                            android:text="Vui lòng chọn ảnh"
                            android:textColor="#999999"
                            android:textSize="14sp" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSelectFile"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:backgroundTint="#00B0FF"
                            android:text="Chọn tệp"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            app:cornerRadius="8dp" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvErrorFile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="*Vui lòng chọn ảnh đại diện"
                        android:textColor="#D32F2F"
                        android:textSize="11sp"
                        android:textStyle="italic"
                        android:visibility="gone" />

                    <!-- Số điện thoại (Fixed) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="15dp"
                        android:text="Số điện thoại"
                        android:textSize="12sp"
                        android:textColor="#999999"/>
                    <TextView
                        android:id="@+id/tvFixedPhone"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:layout_marginTop="5dp"
                        android:background="#EEEEEE"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="15dp"
                        android:text="0916441979"
                        android:textColor="#666666"
                        android:textSize="14sp" />

                    <!-- Buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="40dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCancel"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_marginEnd="10dp"
                            android:layout_weight="1"
                            app:backgroundTint="#9E9E9E"
                            android:text="Hủy"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            app:cornerRadius="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFinish"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            app:backgroundTint="#00B0FF"
                            android:text="Hoàn thành"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            app:cornerRadius="8dp" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
