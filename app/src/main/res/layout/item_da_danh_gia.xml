<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/imgBusLogo"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:src="@drawable/logo"
                app:civ_border_color="#DDDDDD"
                app:civ_border_width="1dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvBusNameDone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Khang Limousine"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <RatingBar
                    android:id="@+id/ratingBarDone"
                    style="?android:attr/ratingBarStyleSmall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:numStars="5"
                    android:rating="5"
                    android:progressTint="#FFD700" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvCommentDone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Tài xế thân thiện, mình được đón tận nhà. Xe chạy đúng giờ. Ghế ngồi thoải mái"
            android:textColor="@color/black"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp" />

        <TextView
            android:id="@+id/tvTravelDateDone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Ngày đi: 13/04/2026"
            android:textColor="#888888"
            android:textSize="13sp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
