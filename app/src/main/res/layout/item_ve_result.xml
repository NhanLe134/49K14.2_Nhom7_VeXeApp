<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    app:cardCornerRadius="15dp"
    app:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="6dp"
                        android:layout_height="7dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/ic_dot_green" />
                    <TextView
                        android:id="@+id/tvTimeResult"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="07:00"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:textSize="15sp"/>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BX Trung tâm Đà Nẵng" android:textColor="#888888" android:textSize="12sp" android:layout_marginStart="16dp"/>

                <View android:layout_width="1dp" android:layout_height="15dp" android:background="#DDDDDD" android:layout_marginStart="4dp" android:layout_marginVertical="4dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/ic_dot_red" android:layout_marginEnd="8dp"/>
                    <TextView
                        android:id="@+id/tvEndTimeResult"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="09:30"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:textSize="15sp"/>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Trung tâm TP Huế" android:textColor="#888888" android:textSize="12sp" android:layout_marginStart="16dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:gravity="end"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvPriceResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="130.000đ"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvEmptySeats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 chỗ trống"
                    android:textColor="#27AE60"
                    android:textSize="13sp" />
            </LinearLayout>
        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:id="@+id/layoutNhaXe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:layout_width="60dp"
                    android:layout_height="50dp"
                    app:cardCornerRadius="8dp">
                    <ImageView
                        android:id="@+id/imgNhaXe"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/kh_home_1" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvNhaXeName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nhà xe Thành Hải"
                        android:textColor="#000000"
                        android:textStyle="bold"
                        android:textSize="15sp"/>
                    <TextView
                        android:id="@+id/tvCarType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xe 4 chỗ"
                        android:textColor="#888888"
                        android:textSize="12sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐ 4.2 (10 đánh giá)"
                        android:textColor="#34B5F1"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btnSelectSeat"
                android:layout_width="100dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:backgroundTint="#FFD700"
                android:text="Chọn chỗ"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:textSize="13sp"
                app:cornerRadius="15dp" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/baseline_check_circle_outline_24"
                app:tint="#27AE60" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="Xác nhận chỗ ngay"
                android:textColor="#27AE60"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
