<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    android:layout_margin="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="#0091D5"
            android:padding="15dp">

            <ImageView
                android:id="@+id/imgDollar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:background="@drawable/circle_bg_loaixe"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="#0091D5" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="15dp"
                android:layout_toEndOf="@id/imgDollar"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cập nhật giá vé"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDialogCarName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loại xe A (4 chỗ)"
                    android:textColor="#E0F2FE"
                    android:textSize="12sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/btnCancelUpdateTop"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/white" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="#F3F4F6"
                android:paddingHorizontal="15dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Giá hiện tại"
                    android:textColor="#6B7280" />

                <TextView
                    android:id="@+id/tvDialogCurrentPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:textColor="#111827"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvUnsetLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@android:drawable/btn_default"
                    android:backgroundTint="#FFEDD5"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="Chưa thiết lập"
                    android:textColor="#9A3412"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Giá vé mới *"
                android:textColor="#111827"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtNewPrice"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@android:drawable/editbox_background"
                android:hint="Nhập giá mới"
                android:inputType="number"
                android:paddingHorizontal="15dp"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvErrorPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Vui lòng nhập giá vé hợp lệ"
                android:textColor="#EF4444"
                android:textSize="12sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnSavePrice"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="25dp"
                android:backgroundTint="#0091D5"
                android:text="Lưu"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:cornerRadius="8dp" />

            <Button
                android:id="@+id/btnCancelUpdate"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="10dp"
                android:text="Hủy thao tác"
                android:textAllCaps="false"
                android:textColor="#0091D5"
                app:cornerRadius="8dp"
                app:strokeColor="#0091D5" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>